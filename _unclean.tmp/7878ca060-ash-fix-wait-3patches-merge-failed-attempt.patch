+				} else
+#endif
+				{
 					if (jp->state == JOBRUNNING)
 						break;
 					jp->waited = 1;
+				}
+				/* check the remaining jobs for a running job (to wait for)
+				 * or a non-running job to mark as waited or return if '-n'
+				 */
 				jp = jp->prev_job;
 			}
 	/* man bash:
@@ -4879,30 +4950,85 @@ oneout:
 		}
 	}
 
+#if BASH_WAIT_N
+	if (one)
 		retval = 127;
+#endif
+
+	/* wait with IDs */
 	do {
-		if (**argv != '%') {
+		if (**argv == '%') {
+			jp = getjob(*argv, 0);
