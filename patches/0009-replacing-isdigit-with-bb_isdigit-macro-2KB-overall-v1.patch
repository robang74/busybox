From 447608b73faf433d5d227d79a84cc0a18c043bea Mon Sep 17 00:00:00 2001
From: "Roberto A. Foglietta" <roberto.foglietta@gmail.com>
Date: Fri, 8 May 2026 02:49:07 +0200
Subject: [PATCH] Replacing isdigit() with bb_isdigit() macro: -2KB
 all-yes-config

define bb_isdigit(c) ({ uint8_t _c = (c); (_c-'0' < 10); })

